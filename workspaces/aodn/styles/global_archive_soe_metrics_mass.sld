<?xml version="1.0" encoding="UTF-8"?>
<StyledLayerDescriptor version="1.0.0"
  xmlns:gml="http://www.opengis.net/gml"
  xmlns:ogc="http://www.opengis.net/ogc"
  xmlns="http://www.opengis.net/sld">
    <NamedLayer>
        <Name>Global Archive SOE - Species greater 200 cm</Name>
        <UserStyle>
            <Name>Global Archive SOE - Species greater 200 cm</Name>
            <Title>Geoserver style</Title>
            <Abstract>Generated by GeoServer</Abstract>
            <FeatureTypeStyle>

                        <Rule>
                    <Name>No species > 200 cm</Name>
                    <Title>No species > 200 cm</Title>
                    <ogc:Filter>
                            <ogc:PropertyIsNull>
                                <ogc:PropertyName>number_species_greater_200cm</ogc:PropertyName>
                            </ogc:PropertyIsNull>
                    </ogc:Filter>
                            <PointSymbolizer>
            <Graphic>
              <Mark>
                <WellKnownName>x</WellKnownName>
                <Fill>
                  <CssParameter name="fill">#006400</CssParameter>
                </Fill>
              </Mark>
              <Opacity>0.1</Opacity>                
              <Size>6</Size>        
            </Graphic>
          </PointSymbolizer>
                </Rule>              
              
                        <Rule>
                    <Name>number_species_greater_200cm_between0and5</Name>
                    <Title>0 &lt;= x &lt; 5 (species > 200cm/site)</Title>
                    <ogc:Filter>
                        <ogc:And>
                            <ogc:PropertyIsGreaterThanOrEqualTo>
                                <ogc:PropertyName>number_species_greater_200cm</ogc:PropertyName>
                                <ogc:Literal>0</ogc:Literal>
                            </ogc:PropertyIsGreaterThanOrEqualTo>
                            <ogc:PropertyIsLessThan>
                                <ogc:PropertyName>number_species_greater_200cm</ogc:PropertyName>
                                <ogc:Literal>5</ogc:Literal>
                            </ogc:PropertyIsLessThan>
                        </ogc:And>
                    </ogc:Filter>
                    <PointSymbolizer>
                        <Graphic>
                            <Mark>
                                <WellKnownName>circle</WellKnownName>
                         <Fill>
                         <CssParameter name="fill">
                            <ogc:Function name="Categorize">
                            <ogc:Div>
                                <ogc:PropertyName>mass_species_greater_200g</ogc:PropertyName>
                                <ogc:Literal>1</ogc:Literal>
                            </ogc:Div>
                                    <ogc:Literal>#FFFFFF</ogc:Literal>
                                     <ogc:Literal>0</ogc:Literal>
                                     <ogc:Literal>#DFEBDF</ogc:Literal>
                                     <ogc:Literal>4000</ogc:Literal>
                                    <ogc:Literal>#BFD8BF</ogc:Literal>
                                    <ogc:Literal>8000</ogc:Literal>
                                     <ogc:Literal>#9FC49F</ogc:Literal>
                                     <ogc:Literal>15000</ogc:Literal>
                                    <ogc:Literal>#7FB17F</ogc:Literal>
                                    <ogc:Literal>30000</ogc:Literal>
                                     <ogc:Literal>#5F9E5F</ogc:Literal>
                                     <ogc:Literal>50000</ogc:Literal>
                                    <ogc:Literal>#3F8A3F</ogc:Literal>
                                    <ogc:Literal>750000</ogc:Literal>
                                     <ogc:Literal>#1F771F</ogc:Literal>
                                     <ogc:Literal>100000</ogc:Literal>
                                    <ogc:Literal>#006400</ogc:Literal>
                          </ogc:Function>
                      </CssParameter>
                     </Fill>
                            </Mark>
                            <Opacity>1</Opacity>
                            <Size>6</Size>
                        </Graphic>
                    </PointSymbolizer>
                </Rule>
 
                 <Rule>
                    <Name>number_species_greater_200cm_between5and10</Name>
                    <Title>5 &lt;= x &lt; 10 (species > 200cm/site)</Title>
                    <ogc:Filter>
                        <ogc:And>
                            <ogc:PropertyIsGreaterThanOrEqualTo>
                                <ogc:PropertyName>number_species_greater_200cm</ogc:PropertyName>
                                <ogc:Literal>5</ogc:Literal>
