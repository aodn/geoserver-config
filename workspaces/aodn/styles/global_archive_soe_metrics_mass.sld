                                    <ogc:Literal>#7FB17F</ogc:Literal>
                                    <ogc:Literal>30000</ogc:Literal>
                                     <ogc:Literal>#5F9E5F</ogc:Literal>
                                     <ogc:Literal>50000</ogc:Literal>
                                    <ogc:Literal>#3F8A3F</ogc:Literal>
                                    <ogc:Literal>750000</ogc:Literal>
                                     <ogc:Literal>#1F771F</ogc:Literal>
                                     <ogc:Literal>100000</ogc:Literal>
