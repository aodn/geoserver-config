                            <Size>14</Size>
                        </Graphic>
                    </PointSymbolizer>
                </Rule>
              
                <Rule>
                    <Name>number_species_greater_200cm_greater_than50</Name>
                  <Title>Greater than 50 (species > 200cm/site)</Title>
                    <ogc:Filter>
